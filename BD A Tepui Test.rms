/* Test script for placing the cliffs on Tepui. */

/* Placeholders */
#const PHON 1543
#const PHONL 1544

#const FOREST_OAK_BUSH 20
#const UNDERBRUSH_JUNGLE 77
#const RAINFOREST_GRASS 83
#const DLC_BOULDER_A 1048
#const ROCK2 1323
#const ROCK_LIMESTONE 2009

/* Cliff values. */
#const GRAPHICS_CLIFF_LIMESTONE 1577
/* Unlabelled objects are unused. */
#const CLIFF_LIMESTONE_01 2069 /* 3 x 3 */
#const CLIFF_LIMESTONE_02 2070 /* 1 x 3 */
#const CLIFF_LIMESTONE_03 2071 /* 3 x 1 */
#const CLIFF_LIMESTONE_04 2072 /* 2 x 3 */
#const CLIFF_LIMESTONE_05 2073
#const CLIFF_LIMESTONE_06 2074 /* 3 x 2 */
#const CLIFF_LIMESTONE_07 2075
#const CLIFF_LIMESTONE_08 2076 /* 1 x 1 */
#const CLIFF_LIMESTONE_09 2077

#const CLIFF_FACET_0_CONST 2074
#const CLIFF_FACET_1_CONST 2069
#const CLIFF_FACET_2_CONST 2069
#const CLIFF_FACET_3_CONST 2069
#const CLIFF_FACET_4_CONST 2069
#const CLIFF_FACET_5_CONST 2069
#const CLIFF_FACET_6_CONST 2072
#const CLIFF_FACET_7_CONST 2070
#const CLIFF_FACET_8_CONST 2070
#const CLIFF_FACET_9_CONST 2076
#const CLIFF_FACET_10_CONST 2071
#const CLIFF_FACET_11_CONST 2071
#const CLIFF_FACET_12_CONST 2072
#const CLIFF_FACET_13_CONST 2076
#const CLIFF_FACET_14_CONST 2074
#const CLIFF_FACET_15_CONST 2069
#const CLIFF_FACET_16_CONST 2069
#const CLIFF_FACET_17_CONST 2069
#const CLIFF_FACET_18_CONST 2069
#const CLIFF_FACET_19_CONST 2069
#const CLIFF_FACET_20_CONST 2071
#const CLIFF_FACET_21_CONST 2071
#const CLIFF_FACET_22_CONST 2070
#const CLIFF_FACET_23_CONST 2070

/* 9-Villager constants. */
#const HERDABLE_A CAPYBARA
#const STRAGGLER DLC_AFRICANBUSH

#MKCONSTS

#const T1 rnd(0,359)
#const TOFF rnd(135,225)
#const T2 (T1 + TOFF)
#const R 24
#FOR($i, 1, 3)
  #TRIG(T$i)
  #const X$i (R * COS_T$i + 50)
  #const Y$i (R * SIN_T$i + 50)
#END_FOR

<PLAYER_SETUP>
direct_placement
behavior_version 2
ai_info_map_type SOCOTRA 0 0 0

#SETPHATTR

/* Adjusts the x and y radii of cliff objects to prevent overlap deletion. */

/* 3 x 3 */
effect_amount GAIA_SET_ATTRIBUTE CLIFF_LIMESTONE_01 ATTR_RADIUS_1 0
effect_amount GAIA_SET_ATTRIBUTE CLIFF_LIMESTONE_01 ATTR_RADIUS_2 0
/* 1 x 3 */
effect_amount GAIA_SET_ATTRIBUTE CLIFF_LIMESTONE_02 ATTR_RADIUS_1 0.1
effect_amount GAIA_SET_ATTRIBUTE CLIFF_LIMESTONE_02 ATTR_RADIUS_2 0.3
/* 3 x 1 */
effect_amount GAIA_SET_ATTRIBUTE CLIFF_LIMESTONE_03 ATTR_RADIUS_1 0.3
effect_amount GAIA_SET_ATTRIBUTE CLIFF_LIMESTONE_03 ATTR_RADIUS_2 0.1
/* 2 x 3 */
effect_amount GAIA_SET_ATTRIBUTE CLIFF_LIMESTONE_04 ATTR_RADIUS_1 0
effect_amount GAIA_SET_ATTRIBUTE CLIFF_LIMESTONE_04 ATTR_RADIUS_2 0
/* 3 x 2 */
effect_amount GAIA_SET_ATTRIBUTE CLIFF_LIMESTONE_06 ATTR_RADIUS_1 0
effect_amount GAIA_SET_ATTRIBUTE CLIFF_LIMESTONE_06 ATTR_RADIUS_2 0
/* 2 x 2 */
effect_amount GAIA_SET_ATTRIBUTE CLIFF_LIMESTONE_08 ATTR_RADIUS_1 0
effect_amount GAIA_SET_ATTRIBUTE CLIFF_LIMESTONE_08 ATTR_RADIUS_2 0

#FOR($i, 1, 10)
  effect_amount GAIA_SET_ATTRIBUTE CLIFF_LIMESTONE_0$i ATTR_OBSTRUCTION_TYPE 0
  effect_amount GAIA_SET_ATTRIBUTE CLIFF_LIMESTONE_0$i ATTR_BLOCKAGE_CLASS 0
#END_FOR

/* Makes Rock 2 invisible, to use as an impenetrable barrier. */
effect_amount GAIA_SET_ATTRIBUTE ROCK2 ATTR_STANDING_GRAPHIC 0

/* Sets bird Line of Sight to 0. */
effect_amount SET_ATTRIBUTE HAWK ATTR_LINE_OF_SIGHT 0
effect_amount SET_ATTRIBUTE MACAW ATTR_LINE_OF_SIGHT 0

<LAND_GENERATION>
base_terrain RAINFOREST_GRASS
enable_waves 0

#FOR($i, 1, 3)
  create_land {
    land_position X$i Y$i
    assign_to AT_TEAM -10 0 0
    terrain_type DIRT
    number_of_tiles 0
  }
#END_FOR

create_land {
  land_position 50 50
  terrain_type DIRT
  number_of_tiles 0
  base_size 42
  set_circular_base
}

<ELEVATION_GENERATION>
create_elevation 2 {
  enable_balanced_elevation
  base_terrain DIRT
  number_of_tiles 300
  number_of_clumps 10
}

<TERRAIN_GENERATION>
#REPEAT(8)
  create_terrain DLC_JUNGLEGRASS {
    base_terrain RAINFOREST_GRASS
    land_percent 100
    number_of_clumps 8192
    spacing_to_other_terrain_types 12
  }
#END_REPEAT

/* Outside trees and mixing. */
create_terrain JUNGLE {
  base_terrain DLC_JUNGLEGRASS
  land_percent 12
  number_of_clumps 128
  spacing_to_other_terrain_types 1
}

create_terrain DLC_RAINFOREST {
  base_terrain DLC_JUNGLEGRASS
  land_percent 8
  number_of_clumps 128
  spacing_to_other_terrain_types 1
}

create_terrain UNDERBRUSH_JUNGLE {
  base_terrain DLC_JUNGLEGRASS
  land_percent 100
  number_of_clumps 64
}

#REPEAT(8)
  create_terrain UNDERBRUSH_JUNGLE {
    base_terrain DLC_JUNGLEGRASS
    land_percent 100
    number_of_clumps 8192
    terrain_mask 1
  }
#END_REPEAT

/* Player Forests */
#REPEAT(8)
  create_terrain DLC_BLACK {
    base_terrain DIRT
    land_percent 100
    number_of_clumps 8192
    set_avoid_player_start_areas 24
  }
#END_REPEAT

create_terrain ROAD {
  base_terrain DIRT
  land_percent 100
  spacing_to_other_terrain_types 2
}

create_terrain ROAD2 {
  base_terrain DIRT
  land_percent 100
  spacing_to_other_terrain_types 2
  spacing_to_specific_terrain ROAD 4
}

create_terrain FOREST_OAK_BUSH {
  base_terrain ROAD
  number_of_tiles 70
  number_of_clumps 3
  set_avoid_player_start_areas
  spacing_to_other_terrain_types 1
  spacing_to_specific_terrain RAINFOREST_GRASS 5
  clumping_factor 25
}

create_terrain FOREST_OAK_BUSH {
  base_terrain ROAD2
  number_of_tiles 70
  number_of_clumps 3
  set_avoid_player_start_areas
  spacing_to_other_terrain_types 1
  spacing_to_specific_terrain RAINFOREST_GRASS 5
  clumping_factor 25
}

#REPEAT(8)
  create_terrain DIRT {
    base_terrain DLC_BLACK
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

/* Global Forests */
create_terrain FOREST_OAK_BUSH {
  base_terrain DIRT
  number_of_tiles 210
  number_of_clumps 9
  set_avoid_player_start_areas 24
  spacing_to_other_terrain_types 2
  spacing_to_specific_terrain RAINFOREST_GRASS 4
  clumping_factor 25
}

#REPEAT(6)
  create_terrain SOUTH_AMERICAN_FOREST {
    base_terrain FOREST_OAK_BUSH
    land_percent 100
  }
#END_REPEAT

#REPEAT(8)
  create_terrain DIRT {
    base_terrain ROAD
    land_percent 100
    number_of_clumps 8192
  }
  create_terrain DIRT {
    base_terrain ROAD2
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

/* Upper terrain masking. */
create_terrain DLC_DRYGRASS {
  base_terrain DIRT
  land_percent 12
  number_of_clumps 32
  terrain_mask 1
}

create_terrain DIRT3 {
  base_terrain DIRT
  land_percent 8
  number_of_clumps 16
  terrain_mask 1
}

create_terrain GRASS3 {
  base_terrain DIRT
  land_percent 6
  number_of_clumps 12
  terrain_mask 1
}

create_terrain DIRT2 {
  base_terrain DIRT
  land_percent 1
  number_of_clumps 4
  terrain_mask 1
}

/* Making the slopes. */
create_terrain DLC_DIRT4 {
  base_terrain RAINFOREST_GRASS
  land_percent 100
  number_of_clumps 8192
  terrain_mask 1
}

<OBJECTS_GENERATION>
/*
 * Dummy actor areas where cliff objects don't fit.
 * They ensure that all actor areas always are defined,
 * even if no cliff object with the given facet appears in the scenario.
 */
#FOR($i, 0, 25)
  create_actor_area 0 0 facet_$i 0
#END_FOR

create_object_group CHICKENS {
  add_object WILD_CHICKEN_A 50
  add_object WILD_CHICKEN_C 50
}

create_object_group TOP_ROCKS {
  add_object DLC_BOULDER_A 50
  add_object DLC_BOULDER_B 50
}

