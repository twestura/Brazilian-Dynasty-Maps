/* Bridges */
#FOR($i, 1, 3)
  /* Land bridge blockers. */
  create_object PHONL {
    number_of_objects 14400
    place_on_specific_land_id $i
    max_distance_to_other_zones 1
    set_gaia_object_only
    actor_area mid_bridge_avoider
    actor_area_radius 0
  }

  /* Top Right Bridge */
  create_object PHON {
    place_on_specific_land_id $i
    terrain_to_place_on PLAYER_BEACH
    set_gaia_object_only
    find_closest
    avoid_actor_area left_blocker
    avoid_actor_area top_blocker_$i
    avoid_actor_area bottom_blocker_$i
    actor_area bridge_top_right_start
    actor_area_radius 1
  }

  create_object BRIDGE_BOTTOM {
    set_gaia_object_only
    place_on_specific_land_id $i
    find_closest
    actor_area_to_place_in bridge_top_right_start
    avoid_actor_area left_blocker
    avoid_actor_area top_blocker_$i
    avoid_actor_area bottom_blocker_$i
    actor_area bridge_end
    actor_area_radius 5
  }

  create_object BRIDGE_MIDDLE {
    number_of_objects 4
    set_gaia_object_only
    place_on_specific_land_id $i
    find_closest
    avoid_actor_area mid_bridge_avoider
    avoid_actor_area left_blocker
    avoid_actor_area top_blocker_$i
    avoid_actor_area bottom_blocker_$i
    actor_area bridge_middle
    actor_area_radius 4
  }

  create_object BRIDGE_MIDDLE {
    set_gaia_object_only
    number_of_objects 8
    place_on_specific_land_id $i
    terrain_to_place_on RIVER_WATER
    find_closest
    avoid_actor_area mid_bridge_avoider
    avoid_actor_area left_blocker
    avoid_actor_area top_blocker_$i
    avoid_actor_area bottom_blocker_$i
    actor_area bridge_middle
    actor_area_radius 4
  }

  create_object BRIDGE_MIDDLE {
    set_gaia_object_only
    place_on_specific_land_id $i
    find_closest
    min_distance_to_players 10
    avoid_actor_area mid_bridge_avoider
    avoid_actor_area left_blocker
    avoid_actor_area top_blocker_$i
    avoid_actor_area bottom_blocker_$i
    actor_area bridge_middle
    actor_area_radius 4
  }

  create_object BRIDGE_TOP {
    set_gaia_object_only
    place_on_specific_land_id $i
    find_closest
    min_distance_to_players 10
    avoid_actor_area mid_bridge_avoider
    avoid_actor_area left_blocker
    avoid_actor_area top_blocker_$i
    avoid_actor_area bottom_blocker_$i
    actor_area bridge_end
    actor_area_radius 5
  }

  /* Top Left Bridge */
  create_object PHON {
    place_on_specific_land_id $i
    terrain_to_place_on PLAYER_BEACH
    set_gaia_object_only
    find_closest
    avoid_actor_area right_blocker
    avoid_actor_area top_blocker_$i
    avoid_actor_area bottom_blocker_$i
    actor_area bridge_top_left_start
    actor_area_radius 2
  }

  create_object BRIDGE_TOP {
    set_gaia_object_only
    place_on_specific_land_id $i
    find_closest
    actor_area_to_place_in bridge_top_left_start
    avoid_actor_area right_blocker
    avoid_actor_area top_blocker_$i
    avoid_actor_area bottom_blocker_$i
    actor_area bridge_end
    actor_area_radius 5
  }

  create_object BRIDGE_MIDDLE {
    number_of_objects 4
    set_gaia_object_only
    place_on_specific_land_id $i
    find_closest
    avoid_actor_area mid_bridge_avoider
    avoid_actor_area right_blocker
    avoid_actor_area top_blocker_$i
    avoid_actor_area bottom_blocker_$i
    actor_area bridge_middle
    actor_area_radius 4
  }

  create_object BRIDGE_MIDDLE {
    set_gaia_object_only
    number_of_objects 8
    place_on_specific_land_id $i
    terrain_to_place_on RIVER_WATER
    find_closest
    avoid_actor_area mid_bridge_avoider
    avoid_actor_area right_blocker
    avoid_actor_area top_blocker_$i
    avoid_actor_area bottom_blocker_$i
    actor_area bridge_middle
    actor_area_radius 4
  }

  /* create_object BRIDGE_A_MIDDLE {
    set_gaia_object_only
    place_on_specific_land_id $i
    find_closest
    min_distance_to_players 10
    avoid_actor_area mid_bridge_avoider
    avoid_actor_area right_blocker
    avoid_actor_area top_blocker_$i
    avoid_actor_area bottom_blocker_$i
  } */

  create_object BRIDGE_BOTTOM {
    set_gaia_object_only
    place_on_specific_land_id $i
    find_closest
    min_distance_to_players 10
    avoid_actor_area mid_bridge_avoider
    avoid_actor_area right_blocker
    avoid_actor_area top_blocker_$i
    avoid_actor_area bottom_blocker_$i
    actor_area bridge_end
    actor_area_radius 5
  }
#END_FOR

/* Birds */
create_object FLAMINGO {
  number_of_objects 3
}

create_object CONDOR {
  number_of_objects 3
}

/* Player Objects */
#OBJECTS9VILSZEWALL

/* Player Oysters */
create_object OYSTERS {
  number_of_objects 3
  set_gaia_object_only
  #SET_PLACE_FOR_EVERY_PLAYER
  terrain_to_place_on PLAYER_BEACH
  temp_min_distance_group_placement 6
  find_closest_to_map_center
  set_circular_placement
  max_distance_to_players 25
  min_distance_group_placement 1
}

/* Map Shore Fish */
create_object SHORE_FISH {
  number_of_objects 256
  temp_min_distance_group_placement 6
  avoid_actor_area bridge_end
  avoid_actor_area bridge_middle
  min_distance_group_placement 3
}

