      number_of_objects 6
      number_of_groups 4
      set_tight_grouping
      group_placement_radius 2
      min_distance_group_placement 3
      temp_min_distance_group_placement 6
      avoid_forest_zone 3
      min_distance_to_map_edge 3
      max_distance_to_other_zones 3
      avoid_actor_area edge_stone
    }

    create_object GUANACO {
      place_on_specific_land_id $i
      avoid_actor_area edge_border$j
      avoid_actor_area bridge_end

      avoid_actor_area javelina
      avoid_forest_zone 3
      max_distance_to_other_zones 3
      min_distance_to_map_edge 3

      number_of_objects 4
      number_of_groups 3
      set_tight_grouping
      group_placement_radius 3
      temp_min_distance_group_placement 12
    }
  #END_FOR

  /* Edge Middle Objects */
  create_object GOLD {
    place_on_specific_land_id $i
    avoid_actor_area top_bottom_border

    number_of_objects 4
    number_of_groups 2
    set_tight_grouping
    group_placement_radius 2
