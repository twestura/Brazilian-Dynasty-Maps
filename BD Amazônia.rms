  create_actor_area 119 99 top_bottom_border 50

  create_actor_area 0 59 middle_fish_edge_avoider 38
  create_actor_area 119 60 middle_fish_edge_avoider 38
  create_actor_area 0 59 middle_fish_edge_avoider 38
  create_actor_area 119 60 middle_fish_edge_avoider 38
endif

