  create_actor_area 60 117 bottom_blocker_2 23
  create_actor_area 100 117 bottom_blocker_2 23

  create_actor_area 59 59 fish_avoider 44
  create_actor_area 60 60 fish_avoider 44

  create_actor_area 0 0 edge_border0 80
  create_actor_area 119 0 edge_border0 80
