#HEADER_START
/*
 * Amazônia for Brazilian Dyasty.
 * Edited by T-West, March 2026.
 */
#HEADER_END

/*
 * Defeat players if the game mode is not set to random map.
 * Includes a check for the secondary game mode checkboxes.
 */
if ANTIQUITY_MODE
  #define ADMIN_RESTART
elseif RANDOM_MAP
  if REGICIDE
    #define ADMIN_RESTART
  elseif EMPIRE_WARS
    #define ADMIN_RESTART
  elseif SUDDEN_DEATH
    #define ADMIN_RESTART
  endif
else
  #define ADMIN_RESTART
endif
if TINY_MAP
else
  #define ADMIN_RESTART
endif
if DEFAULT_RESOURCES
else
  #define ADMIN_RESTART
endif
if DARK_AGE_START
else
  #define ADMIN_RESTART
endif
if TURBO_MODE
  #define ADMIN_RESTART
endif
if ADMIN_RESTART
  <PLAYER_SETUP>
  guard_state SABOTEUR AMOUNT_GOLD 0 1
endif

/* Placeholders */
#const PHON 1543
#const PHONL 1544

#const BUILDING 199
#const DEAD_BUILDING 278

#const HERDABLE_A CAPYBARA
#const STRAGGLER JUNGLETREE

#MKCONSTS

/* Bridges */
#const BRIDGE_A_TOP 605
#const BRIDGE_A_MIDDLE 606
#const BRIDGE_A_BOTTOM 607
#const BRIDGE_B_TOP 608
#const BRIDGE_B_MIDDLE 609
#const BRIDGE_B_BOTTOM 610

/* Terrains */
#const MUD 76
#const RAINFOREST_GRASS 83

#const BASE0 GRASS2
#const BASE1 GRASS3

#const SPAWN0 DIRT2
#const SPAWN1 DIRT3

#const RIVER_WATER WEEDS_WATER
#const PLAYER_BEACH DLC_BEACH3
#const EDGE_BEACH DLC_BEACH2

/* Determines the orientation that the river runs. */
/* #define TB */
/* #define LR */
start_random
  percent_chance 50 #define TB
  percent_chance 50 #define LR
end_random

if TB
  #const BRIDGE_TOP BRIDGE_A_TOP
  #const BRIDGE_MIDDLE BRIDGE_A_MIDDLE
  #const BRIDGE_BOTTOM BRIDGE_A_BOTTOM
elseif LR
  #const BRIDGE_TOP BRIDGE_B_BOTTOM
  #const BRIDGE_MIDDLE BRIDGE_B_MIDDLE
  #const BRIDGE_BOTTOM BRIDGE_B_TOP
endif

<PLAYER_SETUP>
direct_placement
behavior_version 2
ai_info_map_type RIVERS 0 0 0

#SETPHATTR

/* Ensure certain objects only spawn on their own side. */
effect_amount SET_ATTRIBUTE CAPYBARA ATTR_TERRAIN_ID 8
effect_amount SET_ATTRIBUTE GUANACO ATTR_TERRAIN_ID 8
effect_amount SET_ATTRIBUTE JAVELINA ATTR_TERRAIN_ID 8
effect_amount SET_ATTRIBUTE RELIC ATTR_TERRAIN_ID 8

/* Sets Bird Line of Sight to 0. */
effect_amount SET_ATTRIBUTE CONDOR ATTR_LINE_OF_SIGHT 0
effect_amount SET_ATTRIBUTE FLAMINGO ATTR_LINE_OF_SIGHT 0

/* Hack to make dead fish traps spawn the forest. */
effect_percent GAIA_SET_ATTRIBUTE BUILDING ATTR_RADIUS_1 50
effect_percent GAIA_SET_ATTRIBUTE BUILDING ATTR_RADIUS_2 50
effect_amount GAIA_SET_ATTRIBUTE BUILDING ATTR_FOUNDATION_TERRAIN SOUTH_AMERICAN_FOREST
effect_amount GAIA_SET_ATTRIBUTE BUILDING ATTR_TERRAIN_ID 11
effect_amount GAIA_SET_ATTRIBUTE BUILDING ATTR_HITPOINTS 0
effect_amount GAIA_SET_ATTRIBUTE BUILDING ATTR_STANDING_GRAPHIC 0
effect_amount GAIA_SET_ATTRIBUTE DEAD_BUILDING ATTR_STORAGE_VALUE 0

<LAND_GENERATION>
enable_waves 0
base_terrain RIVER_WATER

create_land {
  terrain_type SPAWN0
  if TB
    land_position rnd(48,52) 17
    top_border 5
    right_border 40
    bottom_border 69
    left_border 41
  elseif LR
    land_position 17 rnd(48,52)
    top_border 40
    right_border 69
    bottom_border 41
    left_border 5
  endif

  base_size 7
  set_circular_base
  assign_to AT_TEAM -10 0 0
  land_id 1
  zone 1
  border_fuzziness 25
  other_zone_avoidance_distance 4
}

create_land {
  terrain_type SPAWN1
  if TB
    land_position rnd(48,52) 83
    top_border 69
    right_border 40
    bottom_border 6
    left_border 41
  elseif LR
    land_position 83 rnd(48,52)
    top_border 40
    right_border 6
    bottom_border 41
    left_border 69
  endif

  base_size 7
  set_circular_base
  assign_to AT_TEAM -10 0 0
  land_id 2
  zone 2
  border_fuzziness 25
  other_zone_avoidance_distance 4
}

create_land {
  terrain_type BASE0
  if TB
    land_position 0 50
    top_border -20
    right_border 70
    bottom_border -20
  elseif LR
    land_position 50 0
    bottom_border 70
  endif
  border_fuzziness 30
  land_id 10
  zone 10
  other_zone_avoidance_distance 4
}

create_land {
  terrain_type BASE1
  if TB
    land_position 99 50
    top_border -20
    bottom_border -20
    left_border 70
  elseif LR
    land_position 50 99
    top_border 70
  endif
  border_fuzziness 30
  land_id 11
  zone 11
  other_zone_avoidance_distance 4
}

create_land {
  terrain_type DLC_MANGROVESHALLOW
  land_position 50 50
  number_of_tiles 0
  set_circular_base
  base_size 17
  land_id 20
  zone 20
  other_zone_avoidance_distance 3
}

<ELEVATION_GENERATION>
#FOR($i, 0, 3)
  create_elevation 2 {
    base_terrain BASE$i
    enable_balanced_elevation
    number_of_tiles 600
    number_of_clumps 8
  }
#END_FOR

<TERRAIN_GENERATION>
/* Balance Forests on each side of the river. */
#FOR($i, 0, 2)
  /* Back Forests */
  #REPEAT(8)
    create_terrain SOUTH_AMERICAN_FOREST {
      base_terrain BASE$i
      spacing_to_other_terrain_types 30
      land_percent 100
      number_of_clumps 8192
    }
  #END_REPEAT

  /* Small Forests */
  create_terrain JUNGLE {
    base_terrain BASE$i
    land_percent 2
    number_of_clumps 8
    spacing_to_other_terrain_types 5
  }
#END_FOR

/* Makes the River thinner. */
#REPEAT(8)
  create_terrain WATER {
    base_terrain WEEDS_WATER
    land_percent 100
    number_of_clumps 8192
    spacing_to_specific_terrain DLC_MANGROVESHALLOW 1
    spacing_to_specific_terrain MUD 2
    spacing_to_specific_terrain BASE0 4
    spacing_to_specific_terrain BASE1 4
  }
#END_REPEAT

#REPEAT(8)
  create_terrain BASE0 {
    base_terrain WEEDS_WATER
    land_percent 100
    number_of_clumps 8192
    spacing_to_specific_terrain BASE1 10
    spacing_to_specific_terrain DLC_MANGROVESHALLOW 1
    spacing_to_specific_terrain MUD 2
  }
#END_REPEAT

#REPEAT(8)
  create_terrain BASE1 {
    base_terrain WEEDS_WATER
    land_percent 100
    number_of_clumps 8192
    spacing_to_specific_terrain BASE0 10
    spacing_to_specific_terrain DLC_MANGROVESHALLOW 2
    spacing_to_specific_terrain MUD 2
  }
#END_REPEAT

#REPEAT(8)
  create_terrain WEEDS_WATER {
    base_terrain WATER
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

/* Adjusts the edges of the Mangrove Circle */
#REPEAT(8)
  create_terrain WATER {
    base_terrain DLC_MANGROVESHALLOW
    land_percent 100
    spacing_to_other_terrain_types 3
  }
#END_REPEAT

create_terrain WEEDS_WATER {
  base_terrain DLC_MANGROVESHALLOW
  number_of_tiles 128
  number_of_clumps 8
}

#REPEAT(8)
  create_terrain DLC_MANGROVESHALLOW {
    base_terrain WATER
    land_percent 100
  }
#END_REPEAT

/* Place Forests in the middle shallows. */
create_terrain DLC_MANGROVEFOREST {
  base_terrain DLC_MANGROVESHALLOW
  number_of_tiles 30
  number_of_clumps 5
  spacing_to_other_terrain_types 2
}

/* Blending in the middle Shallows */
create_terrain RAINFOREST_GRASS {
  base_terrain DLC_MANGROVESHALLOW
  number_of_tiles 150
  number_of_clumps 4
  terrain_mask 1
  spacing_to_specific_terrain WEEDS_WATER 1
}

create_terrain GRASS2 {
  base_terrain DLC_MANGROVESHALLOW
  number_of_tiles 100
  number_of_clumps 4
  terrain_mask 1
  spacing_to_specific_terrain WEEDS_WATER 1
}

/* Player Island Terrain Replacement */
#FOR($i, 0, 2)
  create_terrain MUD {
    base_terrain SPAWN$i
    land_percent 100
    number_of_clumps 8192
    beach_terrain PLAYER_BEACH
  }
#END_FOR

/* Player Island Terrain Masking */
#FOR($i, 0, 2)
  create_terrain LEAVES {
    base_terrain MUD
    number_of_tiles 45
    number_of_clumps 3
    terrain_mask 1
    beach_terrain PLAYER_BEACH
  }
#END_FOR

#FOR($i, 0, 2)
  create_terrain DLC_DRYGRASS {
    base_terrain MUD
    number_of_tiles 60
    number_of_clumps 3
    terrain_mask 1
    beach_terrain PLAYER_BEACH
  }
#END_FOR

/* Edge Terrain Replacement */
#FOR($i, 0, 2)
  #REPEAT(8)
    create_terrain DLC_JUNGLEGRASS {
      base_terrain BASE$i
      land_percent 100
      number_of_clumps 8192
      beach_terrain EDGE_BEACH
    }
  #END_REPEAT
#END_FOR

create_terrain DLC_JUNGLELEAVES {
  base_terrain DLC_JUNGLEGRASS
  land_percent 12
  number_of_clumps 16
  beach_terrain EDGE_BEACH
  terrain_mask 1
}

/* Water Masking */
create_terrain DEEP_WATER {
  base_terrain WEEDS_WATER
  land_percent 3
  number_of_clumps 8
  spacing_to_other_terrain_types 1
  terrain_mask 1
}

create_terrain DLC_WATER4 {
  base_terrain WEEDS_WATER
  land_percent 3
  number_of_clumps 8
  spacing_to_other_terrain_types 1
  terrain_mask 1
}

<CONNECTION_GENERATION>
/* Replace terrain after connections. Without it, only replace prior terrain. */
/* accumulate_connections */

#FOR($i, 10, 12)
  /* Connects the central mangrove to the edges. */
  create_connect_land_zones 20 $i {
    replace_terrain RIVER_WATER DLC_NEWSHALLOW
    replace_terrain DEEP_WATER DLC_NEWSHALLOW
    replace_terrain DLC_WATER4 DLC_NEWSHALLOW
    replace_terrain EDGE_BEACH EDGE_BEACH
    replace_terrain JUNGLE JUNGLE
    replace_terrain DLC_MANGROVEFOREST DLC_MANGROVEFOREST
    replace_terrain DLC_MANGROVESHALLOW DLC_MANGROVESHALLOW
    replace_terrain SOUTH_AMERICAN_FOREST SOUTH_AMERICAN_FOREST
    replace_terrain GRASS GRASS
    replace_terrain GRASS2 GRASS2
    terrain_cost RIVER_WATER 1
    terrain_cost EDGE_BEACH 1
    terrain_cost DEEP_WATER 1
    terrain_cost DLC_WATER4 1
    terrain_cost DLC_MANGROVESHALLOW 2
    terrain_cost DLC_MANGROVEFOREST 2
    terrain_cost SOUTH_AMERICAN_FOREST 5
    terrain_cost JUNGLE 5
    terrain_cost GRASS 5
    terrain_cost GRASS2 5
    terrain_size DLC_MANGROVEFOREST 0 0
    terrain_size DLC_MANGROVESHALLOW 0 0
    terrain_size EDGE_BEACH 0 0
    terrain_size RIVER_WATER 7 2
    terrain_size DEEP_WATER 7 2
    terrain_size DLC_WATER4 7 2
    terrain_size SOUTH_AMERICAN_FOREST 0 0
    terrain_size JUNGLE 0 0
    terrain_size GRASS 0 0
    terrain_size GRASS2 0 0
  }
#END_FOR

<OBJECTS_GENERATION>
if TB
  create_actor_area 20 20 left_blocker 40
  create_actor_area 20 99 left_blocker 40
  create_actor_area 99 20 right_blocker 40
  create_actor_area 99 99 right_blocker 40

  create_actor_area 20 2 top_blocker_1 23
  create_actor_area 60 2 top_blocker_1 23
  create_actor_area 100 2 top_blocker_1 23
