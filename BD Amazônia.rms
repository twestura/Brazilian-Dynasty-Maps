  create_actor_area 39 40 top_blocker_2 53
  create_actor_area 39 80 top_blocker_2 53
  create_actor_area 117 20 bottom_blocker_2 23
  create_actor_area 117 60 bottom_blocker_2 23
  create_actor_area 117 100 bottom_blocker_2 23

  create_actor_area 59 59 fish_avoider 44
  create_actor_area 60 60 fish_avoider 44

  create_actor_area 0 0 edge_border0 80
  create_actor_area 0 119 edge_border0 80
  create_actor_area 119 0 edge_border1 80
  create_actor_area 119 119 edge_border1 80

  create_actor_area 0 0 edge_border_large0 100
  create_actor_area 0 119 edge_border_large0 100
  create_actor_area 119 0 edge_border_large1 100
  create_actor_area 119 119 edge_border_large1 100

  create_actor_area 0 20 top_bottom_border 50
  create_actor_area 119 20 top_bottom_border 50
