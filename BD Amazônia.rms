}

/* Player Trees */
/* Attempt several times to place trees. */
#FOR($i, 1, 3)
  #FOR($iter, 0, 5)
    /* Initial 2 tree spots, assume guaranteed to spawn. */
    create_object PHONL {
      avoid_actor_area tree_success_$i

      number_of_objects 2
      place_on_specific_land_id $i
      set_gaia_object_only

      avoid_actor_area bridge_end
      max_distance_to_other_zones 3
      avoid_actor_area box7
      avoid_forest_zone 3

      temp_min_distance_group_placement 8
      actor_area tree_spot_0_$i_$iter
      actor_area_radius 0
    }

    /* Radius around the intial spots for the 3rd spot to avoid. */
    create_object PHONL {
      avoid_actor_area tree_success_$i
      number_of_objects 2
      place_on_specific_land_id $i
      set_gaia_object_only
      temp_min_distance_group_placement 2
      actor_area_to_place_in tree_spot_0_$i_$iter
      actor_area tree_spacing_$i_$iter
      actor_area_radius 8
    }

    /* 3rd tree spot. */
    create_object PHONL {
      avoid_actor_area tree_success_$i

      place_on_specific_land_id $i
      set_gaia_object_only

      avoid_actor_area bridge_end
      max_distance_to_other_zones 3
      avoid_actor_area box7
      avoid_forest_zone 3
      avoid_actor_area tree_spacing_$i_$iter

      actor_area tree_final_0_$i_$iter
      actor_area_radius 0
    }

    /* Successful case of the 3rd placeholder appearing. */
    create_object BUILDING {
      avoid_actor_area tree_success_$i

      place_on_specific_land_id $i
      set_gaia_object_only
      set_gaia_unconvertible

      number_of_objects 15
      set_tight_grouping
      group_placement_radius 2

      second_object DLC_RAINTREE
      actor_area_to_place_in tree_final_0_$i_$iter

      actor_area tree_success_$i_$iter
      actor_area_radius 8192
    }

    /* Failure object when the 3rd placeholder doesn't appear. */
    create_object PHON {
      avoid_actor_area tree_success_$i
      place_on_specific_land_id $i
      set_gaia_object_only
      avoid_actor_area tree_success_$i_$iter
      actor_area tree_failure_$i_$iter
      actor_area_radius 8192
    }

    /* Place the first two forests on success. */
    create_object BUILDING {
      avoid_actor_area tree_success_$i
      avoid_actor_area tree_failure_$i_$iter

      place_on_specific_land_id $i
      set_gaia_object_only
      set_gaia_unconvertible

      number_of_objects 15
      number_of_groups 2
      temp_min_distance_group_placement 1
      set_tight_grouping
      group_placement_radius 2

      second_object DLC_RAINTREE
      actor_area_to_place_in tree_spot_0_$i_$iter
    }

    /* Overall success object. */
    create_object PHON {
      avoid_actor_area tree_success_$i
      place_on_specific_land_id $i
      set_gaia_object_only
      avoid_actor_area tree_failure_$i_$iter
      actor_area tree_success_$i
      actor_area_radius 8192
    }
  #END_FOR


  /* Backup case when trees cannot be placed. */
  create_object BUILDING {
    place_on_specific_land_id $i
    number_of_objects 15
    number_of_groups 3
    set_tight_grouping
    group_placement_radius 2
    set_gaia_object_only
    set_gaia_unconvertible
    avoid_actor_area bridge_end
    max_distance_to_other_zones 2
    avoid_actor_area box7
    temp_min_distance_group_placement 5
    avoid_forest_zone 3
    actor_area player_forest2
    actor_area_radius 2
    second_object DLC_RAINTREE
    /* second_object KING */
    avoid_actor_area tree_success_$i
  }
#END_FOR

