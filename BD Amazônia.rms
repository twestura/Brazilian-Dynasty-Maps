#FOR($i, 10, 12)
  /* Edge Corner Objects */
  #FOR($j, 0, 2)
    /* Keep one gold in the corner. */
    create_object GOLD {
      place_on_specific_land_id $i
      avoid_actor_area edge_border_large$j
      avoid_actor_area bridge_end

      number_of_objects 2
