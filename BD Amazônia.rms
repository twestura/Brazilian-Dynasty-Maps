  create_actor_area 59 0 middle_fish_edge_avoider 38
  create_actor_area 60 119 middle_fish_edge_avoider 38
  create_actor_area 59 0 middle_fish_edge_avoider 38
  create_actor_area 60 119 middle_fish_edge_avoider 38
elseif LR
  create_actor_area 20 20 left_blocker 40
  create_actor_area 99 20 left_blocker 40
  create_actor_area 20 99 right_blocker 40
  create_actor_area 99 99 right_blocker 40

  create_actor_area 2 20 top_blocker_1 23
