      max_distance_to_other_zones 5
      avoid_actor_area edge_gold
      actor_area edge_stone
      actor_area_radius 6
    }

    /* Second Gold, not restricted as much to the corner. */
    create_object GOLD {
      place_on_specific_land_id $i
      avoid_actor_area edge_border$j
      avoid_actor_area bridge_end

      number_of_objects 2
      temp_min_distance_group_placement 10
      set_tight_grouping
      group_placement_radius 1
      min_distance_group_placement 3
      avoid_forest_zone 3
      min_distance_to_map_edge 3
      max_distance_to_other_zones 5
