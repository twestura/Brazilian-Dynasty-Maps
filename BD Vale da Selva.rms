  max_distance_to_players 9
}

/* TODO avoid being invisible */
create_object SCOUT {
  set_place_for_every_player
  set_circular_placement
  actor_area_to_place_in box8
  find_closest_to_map_center
  avoid_actor_area replacement_rock_1
}

/* Neutral Objects */
create_object STONE {
  set_place_for_every_player
  require_path 0
  generate_for_first_land_only
  set_gaia_object_only
  number_of_objects 4
  group_variance 1
  number_of_groups 6
  set_tight_grouping
  temp_min_distance_group_placement 16
  avoid_forest_zone 4
  avoid_actor_area box35
  min_distance_group_placement 3
  min_distance_to_map_edge 2
  actor_area neutral_stone
  actor_area_radius 7
}

create_object GOLD {
  set_place_for_every_player
  require_path 0
  generate_for_first_land_only
  set_gaia_object_only
  number_of_objects 5
  number_of_groups 7
  set_tight_grouping
  avoid_forest_zone 4
  temp_min_distance_group_placement 18
  avoid_actor_area box25
  min_distance_group_placement 3
  min_distance_to_map_edge 2
  avoid_actor_area neutral_stone
