<ELEVATION_GENERATION>
create_elevation 2 {
  base_terrain DESERT
  enable_balanced_elevation
  number_of_tiles 1024
  number_of_clumps 128
}

#REPEAT(128)
  create_elevation 1 {
    base_terrain DESERT
    enable_balanced_elevation
    number_of_tiles 99999
    number_of_clumps 99999
  }
#END_REPEAT

<TERRAIN_GENERATION>
/* Create an area of lower elevation near the beach. */
#REPEAT(8)
  create_terrain WATER {
    base_terrain MED_WATER
    spacing_to_other_terrain_types 7
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

