/* Player-Specific Forests */
#REPEAT(8)
  create_terrain DIRT {
    base_terrain DESERT
    land_percent 100
    number_of_clumps 8192
    set_avoid_player_start_areas 18
  }
#END_REPEAT

#REPEAT(4)
  create_terrain SNOW {
    base_terrain DESERT
    land_percent 100
    spacing_to_other_terrain_types 1
  }

  #REPEAT(8)
    create_terrain ROAD {
      base_terrain SNOW
      land_percent 100
      number_of_clumps 8192
      spacing_to_specific_terrain DLC_JUNGLEGRASS 17
    }
  #END_REPEAT

  #REPEAT(8)
    create_terrain ROAD2 {
      base_terrain SNOW
      land_percent 100
      number_of_clumps 8192
      spacing_to_specific_terrain ROAD 5
      spacing_to_specific_terrain DLC_JUNGLEGRASS 4
    }
  #END_REPEAT

  create_terrain FOREST {
    base_terrain ROAD
    number_of_tiles 12
    set_avoid_player_start_areas
    spacing_to_specific_terrain DLC_NEWSHALLOW 2
  }

  create_terrain PINE_FOREST {
    base_terrain ROAD
    number_of_tiles 12
    set_avoid_player_start_areas
    spacing_to_specific_terrain FOREST 5
    spacing_to_specific_terrain DLC_NEWSHALLOW 2
  }

  create_terrain SNOW_FOREST {
    base_terrain ROAD2
    number_of_tiles 12
    set_avoid_player_start_areas
    spacing_to_specific_terrain DLC_NEWSHALLOW 2
  }

  create_terrain PINE_FOREST {
    base_terrain ROAD2
    number_of_tiles 12
    set_avoid_player_start_areas
    spacing_to_specific_terrain SNOW_FOREST 5
    spacing_to_specific_terrain DLC_NEWSHALLOW 2
  }

  #REPEAT(2)
    create_terrain PINE_FOREST {
      base_terrain FOREST
      land_percent 100
      number_of_clumps 8192
    }
    create_terrain PINE_FOREST {
      base_terrain SNOW_FOREST
      land_percent 100
      number_of_clumps 8192
    }
  #END_REPEAT

  #REPEAT(8)
    create_terrain GRASS2 {
      base_terrain SNOW
      land_percent 100
      number_of_clumps 8192
    }
    create_terrain GRASS2 {
      base_terrain ROAD
      land_percent 100
      number_of_clumps 8192
    }
    create_terrain GRASS2 {
      base_terrain ROAD2
      land_percent 100
      number_of_clumps 8192
    }
  #END_REPEAT
#END_REPEAT

/* Restore the Desert */
#REPEAT(8)
  create_terrain DESERT {
