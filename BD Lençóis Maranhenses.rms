/* TODO better balance the sheep distrubution */
/* TODO better balance the Relic distrubution */

/*
 * Defeat players if the game mode is not set to random map.
 * Includes a check for the secondary game mode checkboxes.
 */
if ANTIQUITY_MODE
  #define ADMIN_RESTART
elseif RANDOM_MAP
  if REGICIDE
    #define ADMIN_RESTART
  elseif EMPIRE_WARS
    #define ADMIN_RESTART
  elseif SUDDEN_DEATH
    #define ADMIN_RESTART
  endif
else
  #define ADMIN_RESTART
endif
if TINY_MAP
else
  #define ADMIN_RESTART
endif
if DEFAULT_RESOURCES
else
  #define ADMIN_RESTART
endif
if DARK_AGE_START
else
  #define ADMIN_RESTART
endif
if TURBO_MODE
  #define ADMIN_RESTART
endif
if ADMIN_RESTART
  <PLAYER_SETUP>
  guard_state SABOTEUR AMOUNT_GOLD 0 1
endif

/* Objects */
#const PHON 1543
#const PHONN 1546
#const HERDABLE_A CAPYBARA
#const STRAGGLER PALMTREE
#const PLANT_RAINFOREST 1354
#const WHALE 2625

#MKCONSTS

/*
 * Rotates the map.
 * The label refers to the side of the map containing the ocean.
 */
/* #define TOP */
/* #define RIGHT */
/* #define BOTTOM */
/* #define LEFT */
start_random
  percent_chance 25 #define TOP
  percent_chance 25 #define RIGHT
  percent_chance 25 #define BOTTOM
  percent_chance 25 #define LEFT
end_random


/* Oystering Ship constant for the Dock arrow bug fix. */
#const OYSTERING_SHIP 2171

<PLAYER_SETUP>
direct_placement
behavior_version 2
ai_info_map_type ARABIA 0 0 0

#SETPHATTR

/* Sets Bird Line of Sight to 0. */
effect_amount SET_ATTRIBUTE FLAMINGO ATTR_LINE_OF_SIGHT 0
effect_amount SET_ATTRIBUTE MACAW ATTR_LINE_OF_SIGHT 0

/* Keeps objects off of the ponds. */
effect_amount GAIA_SET_ATTRIBUTE DLC_GOAT ATTR_TERRAIN_ID 4
effect_amount GAIA_SET_ATTRIBUTE RELIC ATTR_TERRAIN_ID 4

/* Changes attributes of the Docks used for positioning shore fish. */
effect_amount GAIA_SET_ATTRIBUTE DOCK ATTR_DEAD_ID -1
effect_amount GAIA_SET_ATTRIBUTE DOCK ATTR_HITPOINTS 0
effect_amount GAIA_SET_ATTRIBUTE DOCK ATTR_MAX_RANGE 0
effect_amount GAIA_SET_ATTRIBUTE DOCK ATTR_DYING_GRAPHIC 0
effect_amount GAIA_SET_ATTRIBUTE DOCK ATTR_STANDING_GRAPHIC 0
effect_amount GAIA_SET_ATTRIBUTE DOCK ATTR_STANDING2_GRAPHIC 0
effect_amount GAIA_SET_ATTRIBUTE DOCK ATTR_DESTRUCTION_GRAPHIC 0
effect_amount GAIA_SET_ATTRIBUTE DOCK ATTR_DESTRUCTION_RUBBLE_GRAPHIC 0
effect_amount GAIA_SET_ATTRIBUTE DOCK ATTR_DYING_SOUND -1


/* Ensure that Oystering Ships can attack. */
effect_amount SET_ATTRIBUTE OYSTERING_SHIP ATTR_GARRISON_FIREPOWER -1

<LAND_GENERATION>
enable_waves 0

base_terrain DESERT

/* Ocean */
create_land {
  terrain_type MED_WATER
  border_fuzziness 15
  if TOP
    land_position 50 0
    bottom_border 77
  elseif RIGHT
    land_position 99 50
    top_border -20
    bottom_border -20
    left_border 77
  elseif BOTTOM
    land_position 50 99
    top_border 77
  elseif LEFT
    land_position 0 50
    top_border -20
    bottom_border -20
    right_border 77
  endif
}

/* Forest */
create_land {
  terrain_type DLC_JUNGLEGRASS
  base_elevation 3
  if TOP
    land_position 50 99
    top_border 85
  elseif RIGHT
    land_position 0 50
    top_border -20
    right_border 85
    bottom_border -20
  elseif BOTTOM
    land_position 50 0
    bottom_border 85
  elseif LEFT
    land_position 99 50
    top_border -20
    left_border 85
    bottom_border -20
  endif
}

/* Players */
create_land {
  terrain_type DESERT
  assign_to AT_TEAM -10 0 0
  set_circular_base
  base_size 11
  base_elevation 1
  number_of_tiles 0
  if TOP
    land_position rnd(28,32) 70
  elseif RIGHT
    land_position 30 rnd(28,32)
  elseif BOTTOM
    land_position rnd(28,32) 30
  elseif LEFT
    land_position 70 rnd(28,32)
  endif
}

create_land {
  terrain_type DESERT
  assign_to AT_TEAM -10 0 0
  set_circular_base
  base_size 11
  base_elevation 1
  number_of_tiles 0
  if TOP
    land_position rnd(67,71) 70
  elseif RIGHT
    land_position 30 rnd(67,71)
  elseif BOTTOM
    land_position rnd(67,71) 30
  elseif LEFT
    land_position 70 rnd(67,71)
  endif
}

