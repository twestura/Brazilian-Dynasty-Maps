<OBJECTS_GENERATION>
/* Whale placement areas. */
if TOP
  create_actor_area 15 10 whale_area_1 8
  create_actor_area 45 10 whale_area_2 8
  create_actor_area 74 10 whale_area_3 8
  create_actor_area 104 10 whale_area_4 8
elseif RIGHT
  create_actor_area 109 15 whale_area_1 8
  create_actor_area 109 45 whale_area_2 8
  create_actor_area 109 74 whale_area_3 8
  create_actor_area 109 104 whale_area_4 8
elseif BOTTOM
  create_actor_area 15 109 whale_area_1 8
  create_actor_area 45 109 whale_area_2 8
  create_actor_area 74 109 whale_area_3 8
  create_actor_area 104 109 whale_area_4 8
elseif LEFT
  create_actor_area 10 15 whale_area_1 8
  create_actor_area 10 45 whale_area_2 8
  create_actor_area 10 74 whale_area_3 8
  create_actor_area 10 104 whale_area_4 8
endif

/* Javelina avoidance areas. */
if TOP
  create_actor_area 49 82 middle 16
  create_actor_area 70 82 middle 16
elseif RIGHT
  create_actor_area 37 49 middle 16
  create_actor_area 37 70 middle 16
elseif BOTTOM
  create_actor_area 49 37 middle 16
  create_actor_area 70 37 middle 16
elseif LEFT
  create_actor_area 82 49 middle 16
  create_actor_area 82 70 middle 16
endif

/* Big fish appropriate for the coast of Brazil. */
create_object_group CAPTAIN_FIN {
  add_object TUNA 34
  add_object SNAPPER 33
  add_object DORADO 33
}

/* Birds */
create_object MACAW {
  number_of_objects 5
}

create_object FLAMINGO {
  number_of_objects 2
}

/* Placeholders */
create_object PHON {
  number_of_objects 14400
  terrain_to_place_on DESERT
  layer_to_place_on DLC_JUNGLEGRASS
  actor_area forest_edge
  actor_area_radius 2
}

create_object PHON {
  number_of_objects 14400
  terrain_to_place_on DLC_JUNGLEGRASS
  actor_area mine_avoider
  actor_area_radius 20
}

create_object PHON {
  number_of_objects 14400
  terrain_to_place_on DLC_JUNGLEGRASS
  actor_area relic_avoider
  actor_area_radius 40
}

/* Whales along the edge of the map. */
#FOR($i, 1, 5)
  create_object WHALE {
    actor_area_to_place_in whale_area_$i
    temp_min_distance_group_placement 12
    min_distance_group_placement 6
    max_distance_to_other_zones 10
    min_distance_to_map_edge 5
  }
#END_FOR

/* Places 4 Shore Fish in each pond. */
#FOR($i, 10, 18)
  /* Ensures space is reserved for a Dock. */
  create_object DOCK {
    place_on_specific_land_id $i
    find_closest
    actor_area dock0_$i
    actor_area_radius 0
    avoid_other_land_zones 0
  }

  create_object PHON {
    place_on_specific_land_id $i
    actor_area_to_place_in dock0_$i
    actor_area dock1_$i
    actor_area_radius 1
    avoid_other_land_zones 0
  }

  create_object PHON {
    place_on_specific_land_id $i
    actor_area_to_place_in dock0_$i
    actor_area dock2_$i
    actor_area_radius 2
    avoid_other_land_zones 0
  }

  create_object PHONN {
    place_on_specific_land_id $i
    avoid_actor_area dock1_$i
    actor_area_to_place_in dock2_$i
    second_object SHORE_FISH
    terrain_to_place_on DLC_NEWSHALLOW
    min_distance_group_placement 2
    avoid_other_land_zones 0
  }

  create_object PHONN {
    number_of_objects 3
    place_on_specific_land_id $i
    terrain_to_place_on DLC_NEWSHALLOW
    min_distance_group_placement 2
    second_object SHORE_FISH
    avoid_other_land_zones 0
  }
#END_FOR

