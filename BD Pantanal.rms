/* Player Villagers */
#FOR($i, 1, 3)
  create_object PHON {
    place_on_specific_land_id $i
    set_gaia_object_only
    avoid_actor_area beach1
    find_closest_to_map_center
    terrain_to_place_on MUDDY_SHALLOW
    avoid_actor_area map_middle
    avoid_actor_area villager
    actor_area vil_area_$i
    actor_area_radius 2
  }

  create_object PHON {
    number_of_objects 14400
    actor_area_to_place_in vil_area_$i
    place_on_specific_land_id $i
    set_gaia_object_only
    actor_area capy_avoider
    actor_area_radius 6
  }

  create_object VILLAGER {
    place_on_specific_land_id $i
    actor_area_to_place_in vil_area_$i
    terrain_to_place_on MUDDY_SHALLOW
    actor_area villager
    actor_area_radius 20
  }
#END_FOR

#FOR($i, 1, 3)
  create_object VILLAGER {
    number_of_objects 3
    number_of_groups 2
    place_on_specific_land_id $i
    temp_min_distance_group_placement 30
    min_distance_to_map_edge 20
    min_distance_group_placement 8
    terrain_to_place_on MUDDY_SHALLOW
    avoid_actor_area villager
    actor_area villager
    actor_area_radius 20
  }
#END_FOR

/* Javelinas */
create_object JAVELINA {
  number_of_objects 64
  temp_min_distance_group_placement 14
  terrain_to_place_on MUDDY_SHALLOW
  avoid_actor_area beach2
  avoid_actor_area capy_avoider /* Avoid the starting Villagers. */
  avoid_actor_area map_middle
}

/* Outside Resources */
create_object STONE {
  terrain_to_place_on RAINFOREST_GRASS
  number_of_objects 2
  number_of_groups 32
  set_tight_grouping
  group_placement_radius 1
  temp_min_distance_group_placement 18
  max_distance_to_other_zones 5
  avoid_forest_zone 3
  min_distance_group_placement 2
  actor_area outside_stone
  actor_area_radius 6
}

create_object PAPAYA_TREE {
  terrain_to_place_on RAINFOREST_GRASS
  number_of_objects 4
  number_of_groups 32
  set_tight_grouping
  group_placement_radius 2
  temp_min_distance_group_placement 16
  max_distance_to_other_zones 5
  avoid_forest_zone 3
  min_distance_group_placement 3
  avoid_actor_area outside_stone
}

create_object RHEA {
  number_of_objects 3
  number_of_groups 32
  temp_min_distance_group_placement 16
  set_loose_grouping
  avoid_forest_zone 3
  terrain_to_place_on RAINFOREST_GRASS
}

/* Middle Gold */
#FOR($i, 0, 2)
  /* Place an initial 3 placeholders, assuming they all spawn. */
  create_object PHONL {
    avoid_actor_area island_$i
    
    number_of_objects 3
    terrain_to_place_on DLC_JUNGLEGRASS
    avoid_forest_zone 2
    max_distance_to_other_zones 4
    temp_min_distance_group_placement 10
    actor_area $i_initial_3_0
    actor_area_radius 0
  }
  
  create_object PHON {
    avoid_actor_area island_$i
    number_of_objects 32
    temp_min_distance_group_placement 1
    actor_area_to_place_in $i_initial_3_0
    actor_area $i_initial_3_8
    actor_area_radius 8
  }
  
  create_object PHON {
    avoid_actor_area island_$i
    number_of_objects 32
    temp_min_distance_group_placement 1
    actor_area_to_place_in $i_initial_3_0
    actor_area $i_initial_3_10
    actor_area_radius 10
  }
  
  create_object PHON {
    avoid_actor_area island_$i
    number_of_objects 32
    temp_min_distance_group_placement 1
    actor_area_to_place_in $i_initial_3_0
    actor_area $i_initial_3_12
    actor_area_radius 12
  }
  
  create_object PHON {
    avoid_actor_area island_$i
    number_of_objects 32
    temp_min_distance_group_placement 1
    actor_area_to_place_in $i_initial_3_0
    actor_area $i_initial_3_14
    actor_area_radius 14
  }
  
  /* Place a 4th, 5th, and 6th placeholder. */
  #FOR($j, 4, 7)
    create_object PHONL {
      avoid_actor_area island_$i
      
      terrain_to_place_on DLC_JUNGLEGRASS
      avoid_forest_zone 2
      max_distance_to_other_zones 4
      avoid_actor_area $i_initial_3_14
      
      actor_area $i_$j_placeholder_0
      actor_area_radius 0
    }
    
    create_object PHON {
      avoid_actor_area island_$i
      actor_area_to_place_in $i_$j_placeholder_0
      actor_area $i_$j_placeholder_success
      actor_area_radius 512
    }
    
    create_object PHONL {
      avoid_actor_area island_$i
      avoid_actor_area $i_$j_placeholder_success
      
      terrain_to_place_on DLC_JUNGLEGRASS
      avoid_forest_zone 2
      max_distance_to_other_zones 4
      avoid_actor_area $i_initial_3_12
      
      actor_area $i_$j_placeholder_0
      actor_area_radius 0
    }
    
    create_object PHON {
      avoid_actor_area island_$i
      actor_area_to_place_in $i_$j_placeholder_0
      actor_area $i_$j_placeholder_success
      actor_area_radius 512
    }
    
    create_object PHONL {
      avoid_actor_area island_$i
      avoid_actor_area $i_$j_placeholder_success
      
      terrain_to_place_on DLC_JUNGLEGRASS
      avoid_forest_zone 2
      max_distance_to_other_zones 4
      avoid_actor_area $i_initial_3_10
      
      actor_area $i_$j_placeholder_0
      actor_area_radius 0
    }
    
    create_object PHON {
      avoid_actor_area island_$i
      actor_area_to_place_in $i_$j_placeholder_0
      actor_area $i_$j_placeholder_success
      actor_area_radius 512
    }
    
    create_object PHONL {
      avoid_actor_area island_$i
      avoid_actor_area $i_$j_placeholder_success
      
      terrain_to_place_on DLC_JUNGLEGRASS
      avoid_forest_zone 2
      max_distance_to_other_zones 4
      avoid_actor_area $i_initial_3_8
      
      actor_area $i_$j_placeholder_0
      actor_area_radius 0
    }
    
    create_object PHON {
      avoid_actor_area island_$i
      actor_area_to_place_in $i_$j_placeholder_0
      actor_area $i_initial_3_8
      actor_area_radius 8
    }
    
    create_object PHON {
      avoid_actor_area island_$i
      actor_area_to_place_in $i_$j_placeholder_0
      actor_area $i_initial_3_10
      actor_area_radius 10
    }
    
    create_object PHON {
      avoid_actor_area island_$i
      actor_area_to_place_in $i_$j_placeholder_0
      actor_area $i_initial_3_12
      actor_area_radius 12
    }
    
    create_object PHON {
      avoid_actor_area island_$i
      actor_area_to_place_in $i_$j_placeholder_0
      actor_area $i_initial_3_14
      actor_area_radius 14
    }
    
    create_object PHON {
      avoid_actor_area island_$i
      actor_area_to_place_in $i_$j_placeholder_0
      actor_area $i_$j_success
      actor_area_radius 512
    }
  #END_FOR
  
  /* Places Gold in the initial placedholder areas. */
  create_object GOLD {
    avoid_actor_area island_$i
    actor_area_to_place_in $i_initial_3_0
    number_of_objects 4
    number_of_groups 3
    set_tight_grouping
    group_placement_radius 1
    min_distance_group_placement 2
  }
  
  #FOR($j, 4, 7)
    /* Places Gold in the final 3 placedholder areas. */
    create_object GOLD {
      avoid_actor_area $i_6_success
      avoid_actor_area island_$i
      actor_area_to_place_in $i_$j_placeholder_0
      number_of_objects 4
      set_tight_grouping
      group_placement_radius 1
      min_distance_group_placement 2
      actor_area $i_secondary_gold_placement
      actor_area_radius 512
    }
    
    create_object GOLD {
      avoid_actor_area $i_secondary_gold_placement
      avoid_actor_area island_$i
      actor_area_to_place_in $i_$j_placeholder_0
      number_of_objects 3
      set_tight_grouping
      group_placement_radius 1
      min_distance_group_placement 2
    }
  #END_FOR
#END_FOR

/* Middle Herdables */
create_object CAPYBARA {
  number_of_objects 2
  number_of_groups 32
  set_loose_grouping
  temp_min_distance_group_placement 12
  terrain_to_place_on DLC_JUNGLEGRASS
  avoid_actor_area capy_avoider
}

/* Randomly Spaces Relics */
create_object RELIC {
  number_of_objects 5
  temp_min_distance_group_placement 25
  min_distance_group_placement 1
  avoid_forest_zone 2
  min_distance_to_map_edge 5
}
