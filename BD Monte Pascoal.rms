 #HEADER_START
/*
 * Monte Pascoal for Brazilian Dyasty.
 * Edited by T-West, March 2026.
 */
#HEADER_END

/* TODO keep a consistent number of whales in the corner */

/*
 * Defeat players if the game mode is not set to random map.
 * Includes a check for the secondary game mode checkboxes.
 */
if ANTIQUITY_MODE
  #define ADMIN_RESTART
elseif RANDOM_MAP
  if REGICIDE
    #define ADMIN_RESTART
  elseif EMPIRE_WARS
    #define ADMIN_RESTART
  elseif SUDDEN_DEATH
    #define ADMIN_RESTART
  endif
else
  #define ADMIN_RESTART
endif
if TINY_MAP
else
  #define ADMIN_RESTART
endif
if DEFAULT_RESOURCES
else
  #define ADMIN_RESTART
endif
if DARK_AGE_START
else
  #define ADMIN_RESTART
endif
if TURBO_MODE
  #define ADMIN_RESTART
endif
if ADMIN_RESTART
  <PLAYER_SETUP>
  guard_state SABOTEUR AMOUNT_GOLD 0 1
endif

/* Placeholders */
#const PHON 1543
#const PHONL 1544
#const PHONA 1545

/* Terrains */
#const UNDERBRUSH_JUNGLE 77
#const BEACH_NONNAVIGABLE 79
#const RAINFOREST_GRASS 83
#const PLAYER_BEACH DLC_BEACH2
#const SPAWN0 GRASS2
#const SPAWN1 DLC_DRYGRASS

/* Objects */
#const PLANT_JUNGLE 1351
#const PLANT_UNDERBRUSH_TROPICAL 1352
#const PLANT_UNDERBRUSH 1353
#const PLANT_RAINFOREST 1354
#const PLANT_UNDERBRUSH_RAINFOREST 1355
#const BEACHED_WHALE 2457
#const WHALE 2625

/* Determines the orientation of the mountain. */
/*
 * Coordinates are computed as follows:
 * - North: (x, y)
 * - East: (100 - y, x)
 * - South: (100 - x, 100 - y)
 * - West: (y, 100 - x)
 * Take care that 0 is allowed as a land position but 100 is not (use 99).
 */
/* #define NORTH */
/* #define EAST */
/* #define SOUTH */
/* #define WEST */
start_random
  percent_chance 25 #define NORTH
  percent_chance 25 #define EAST
  percent_chance 25 #define SOUTH
  percent_chance 25 #define WEST
end_random


/* Oystering Ship constant for the Dock arrow bug fix. */
#const OYSTERING_SHIP 2171

<PLAYER_SETUP>
direct_placement
nomad_resources
behavior_version 2
ai_info_map_type NOMAD 1 0 0

/* Sets Bird Line of Sight to 0. */
effect_amount SET_ATTRIBUTE MACAW ATTR_LINE_OF_SIGHT 0

/* Makes Rugs spawn only on the Villager islands. */
effect_amount SET_ATTRIBUTE RUGS ATTR_TERRAIN_ID 50


/* Ensure that Oystering Ships can attack. */
effect_amount SET_ATTRIBUTE OYSTERING_SHIP ATTR_GARRISON_FIREPOWER -1

<LAND_GENERATION>
enable_waves 1
base_terrain SNOW

/* Mountain Top North Corner */
create_land {
  if NORTH
    land_position 99 0
  elseif EAST
    land_position 99 99
  elseif SOUTH
    land_position 0 99
  elseif WEST
    land_position 0 0
  endif
  terrain_type DLC_CRACKED
  base_elevation 7
  number_of_tiles 0
  zone 10
}

/* Mountain Top */
create_land {
  if NORTH
    land_position 90 10
  elseif EAST
    land_position 90 90
  elseif SOUTH
    land_position 10 90
  elseif WEST
    land_position 10 10
  endif
  terrain_type DLC_CRACKED
  base_size 13
  base_elevation 7
  number_of_tiles 1000
  clumping_factor 30
  zone 10
}

/* Coast Edge */
if NORTH
  create_land { land_position 30 0 terrain_type DESERT set_circular_base base_size 10 number_of_tiles 256 zone 10 other_zone_avoidance_distance 8 }
