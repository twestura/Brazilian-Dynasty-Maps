/* Gap Between Beach and Mountain */
create_land {
  terrain_type DLC_JUNGLEGRASS
  if NORTH
    land_position 65 35
  elseif EAST
    land_position 65 65
  elseif SOUTH
    land_position 35 65
  elseif WEST
    land_position 35 35
  endif
}

/* Islands */
create_land {
  if NORTH
    land_position rnd(10,15) rnd(35,60)
  elseif EAST
    land_position rnd(40,65) rnd(10,15)
  elseif SOUTH
    land_position rnd(85,90) rnd(40,65)
  elseif WEST
    land_position rnd(35,60) rnd(85,90)
  endif
  terrain_type SPAWN0
  number_of_tiles 500
  base_size 6
  top_border 4
  right_border 5
  bottom_border 5
  left_border 4
  zone 20
  other_zone_avoidance_distance 8
  assign_to AT_TEAM -10 0 0
}

create_land {
  if NORTH
    land_position rnd(40,65) rnd(85,90)
  elseif EAST
    land_position rnd(10,15) rnd(40,65)
  elseif SOUTH
    land_position rnd(35,60) rnd(10,15)
  elseif WEST
    land_position rnd(85,90) rnd(35,60)
  endif
  terrain_type SPAWN1
  number_of_tiles 500
  base_size 6
  top_border 4
  right_border 5
  bottom_border 5
  left_border 4
  zone 21
  other_zone_avoidance_distance 8
  assign_to AT_TEAM -10 0 0
}

<ELEVATION_GENERATION>
create_elevation 2 {
  base_terrain DLC_JUNGLEGRASS
  enable_balanced_elevation
  number_of_tiles 800
  number_of_clumps 8
}

#REPEAT(8)
  create_elevation 10 {
    base_terrain DLC_CRACKED
    enable_balanced_elevation
    spacing 7
    number_of_tiles 99999
    number_of_clumps 99999
  }
#END_REPEAT

<TERRAIN_GENERATION>
/* Cover holes in the player lands. */
#FOR($i, 0, 2)
  #REPEAT(8)
    create_terrain ROAD {
      base_terrain SNOW
      land_percent 100
      number_of_clumps 8192
      spacing_to_specific_terrain SPAWN$i 2
    }
  #END_REPEAT
  #REPEAT(8)
    create_terrain SPAWN$i {
      base_terrain SNOW
      land_percent 100
      number_of_clumps 8192
      spacing_to_specific_terrain ROAD 3
    }
  #END_REPEAT

  #REPEAT(8)
    create_terrain SNOW {
      base_terrain ROAD
      land_percent 100
      number_of_clumps 8192
    }
  #END_REPEAT
#END_FOR

/* Place Water in the south. */
#REPEAT(8)
  create_terrain WATER {
    base_terrain SNOW
    spacing_to_specific_terrain DLC_JUNGLEGRASS 5
    spacing_to_specific_terrain DLC_CRACKED 10
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

/* Covers the top of the hill with DLC_CRACKED. */
#REPEAT(8)
  create_terrain DLC_CRACKED {
    base_terrain DLC_JUNGLEGRASS
    land_percent 100
    number_of_clumps 8192
    height_limits 6 10
  }
  create_terrain DLC_CRACKED {
    base_terrain SNOW
    land_percent 100
    number_of_clumps 8192
    height_limits 6 10
  }
#END_REPEAT

/* Covers snow patches. */
#REPEAT(8)
  create_terrain DESERT {
    base_terrain SNOW
    land_percent 100
    number_of_clumps 8192
    spacing_to_specific_terrain DLC_JUNGLEGRASS 1
  }
#END_REPEAT

#REPEAT(8)
  create_terrain DLC_JUNGLEGRASS {
    base_terrain SNOW
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

/* Covers Desert lands intersecting the placeholder. */
#REPEAT(8)
  create_terrain ROAD {
    base_terrain DESERT
    spacing_to_specific_terrain DLC_JUNGLEGRASS 1
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

#REPEAT(8)
  create_terrain DLC_JUNGLEGRASS {
    base_terrain DESERT
    spacing_to_specific_terrain ROAD 1
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

#REPEAT(8)
  create_terrain DESERT {
    base_terrain ROAD
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

/* Desert to Jungle Transition */
#REPEAT(8)
  create_terrain ROAD {
    base_terrain DLC_JUNGLEGRASS
    land_percent 100
    number_of_clumps 8192
    spacing_to_specific_terrain DESERT 3
  }
#END_REPEAT

#REPEAT(8)
  create_terrain DESERT {
    base_terrain DLC_JUNGLEGRASS
    land_percent 100
    number_of_clumps 8192
    terrain_mask 1
    spacing_to_specific_terrain ROAD 2
  }
#END_REPEAT

create_terrain DLC_QUICKSAND {
  base_terrain DLC_JUNGLEGRASS
  number_of_tiles 64
  number_of_clumps 8
  terrain_mask 1
}

#REPEAT(8)
  create_terrain DLC_JUNGLEGRASS {
    base_terrain ROAD
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

/* Covers water holes on the beach. */
#REPEAT(8)
  create_terrain MED_WATER {
    base_terrain WATER
    spacing_to_specific_terrain DESERT 2
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

#REPEAT(8)
  create_terrain DESERT {
    base_terrain WATER
    spacing_to_specific_terrain MED_WATER 3
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

#REPEAT(8)
  create_terrain DLC_WATER5 {
    base_terrain WATER
    land_percent 100
    number_of_clumps 8192
  }
  create_terrain DLC_WATER5 {
    base_terrain MED_WATER
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

/* DLC_CRACKED masking near the top of the hill. */
create_terrain DLC_CRACKED {
  base_terrain DLC_JUNGLEGRASS
  land_percent 100
  number_of_clumps 8192
  terrain_mask 2
  height_limits 5 10
}

/* Player Island Generation */
#FOR($i, 0, 2)
  create_terrain DLC_RAINFOREST {
    base_terrain SPAWN$i
    number_of_tiles 50
    number_of_clumps 5
    set_avoid_player_start_areas 7
    spacing_to_other_terrain_types 2
    clumping_factor 25
  }

  #REPEAT(8)
    create_terrain RAINFOREST_GRASS {
      base_terrain SPAWN$i
      land_percent 100
      number_of_clumps 8192
      beach_terrain PLAYER_BEACH
    }
  #END_REPEAT
#END_FOR

create_terrain UNDERBRUSH_JUNGLE {
  base_terrain RAINFOREST_GRASS
  number_of_tiles 128
  number_of_clumps 4
