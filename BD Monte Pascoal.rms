  create_land { land_position 35 70 terrain_type DESERT set_circular_base base_size 10 number_of_tiles 512 zone 10 other_zone_avoidance_distance 8 }
  create_land { land_position 30 80 terrain_type DESERT set_circular_base base_size 10 number_of_tiles 512 zone 10 other_zone_avoidance_distance 8 }
