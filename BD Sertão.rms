/* Map Objects */
create_object GOLD {
  place_on_specific_land_id GOLD_ID
  number_of_objects 5
  find_closest
  set_tight_grouping
  avoid_cliff_zone 3
  min_distance_group_placement 2
  actor_area pit_mine
  actor_area_radius 5
}

create_object STONE {
  place_on_specific_land_id STONE_ID
  number_of_objects 4
  find_closest
  set_tight_grouping
  avoid_cliff_zone 3
  min_distance_group_placement 2
  actor_area pit_mine
  actor_area_radius 5
}

/* Relics */
create_object RELIC {
  number_of_objects 4
  /*
   * Using 40 produces a better Relic distribution in general.
   * But the tradeoff is that occasionally only 3 of out the 4
   * spawn, resulting in a missing Relic.
   * For now we'll prefer having all 5 Relics, but this is an area
   * for improvement with a more robust system for placing the
   * inital 4 Relics.
   */
  temp_min_distance_group_placement 30
  set_circular_placement
  min_distance_to_players 35
  avoid_forest_zone 1
  avoid_cliff_zone 3
  avoid_actor_area corner_a
  avoid_actor_area corner_b
  avoid_actor_area edge_behind_players
  actor_area relic0
  actor_area_radius 0
}

create_object PHON {
  number_of_objects 4
  temp_min_distance_group_placement 30
  actor_area_to_place_in relic0
  actor_area relic16
  actor_area_radius 16
}

create_object PHON {
  number_of_objects 4
