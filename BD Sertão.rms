/*
 * Check for TC spots in the pits.
 * Note this requires the Gold, Stone, and Rock objects in the pits to have
 * their min distance group placement commented out.
 */
/* create_object TOWN_CENTER {
  place_on_specific_land_id GOLD_ID
  find_closest
}

create_object TOWN_CENTER {
  place_on_specific_land_id STONE_ID
  find_closest
} */
